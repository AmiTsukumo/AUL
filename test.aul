// AUL Test Program

// Test 1: Basic variables and arithmetic
print("=== Test 1: Variables and Arithmetic ===")
var x = 10
val y = 20
print("x = ")
print(x)
print("y = ")
print(y)
print("x + y = ")
print(x + y)
print("x * y = ")
print(x * y)

// Test 2: Function definition
print("=== Test 2: Functions ===")
func add(a, b) {
    a + b ~
}

func multiply(a, b) {
    a * b ~
}

print("add(5, 3) = ")
print(add(5, 3))
print("multiply(4, 7) = ")
print(multiply(4, 7))

// Test 3: Control flow
print("=== Test 3: If/Else ===")
func describe(num) {
    if num > 0 {
        "positive" ~
    } elif num < 0 {
        "negative" ~
    } else {
        "zero" ~
    }
}

print("describe(5) = ")
print(describe(5))
print("describe(-3) = ")
print(describe(-3))
print("describe(0) = ")
print(describe(0))

// Test 4: While loop
print("=== Test 4: While Loop ===")
var count = 0
while count < 3 {
    print("count = ")
    print(count)
    count = count + 1
}

// Test 5: For loop (numeric)
print("=== Test 5: For Loop ===")
for i = 0, 4 {
    print("i = ")
    print(i)
}

// Test 6: String concatenation
print("=== Test 6: String Concatenation ===")
var name = "Alice"
var greeting = "Hello, " .. name
print(greeting)

// Test 7: Boolean operations
print("=== Test 7: Boolean Operations ===")
print("true and false = ")
print(true and false)
print("true or false = ")
print(true or false)
print("not true = ")
print(not true)

// Test 8: Tables
print("=== Test 8: Tables ===")
var person = {
    "name" = "Bob",
    "age" = 30
}
print("person[\"name\"] = ")
print(person["name"])
print("person[\"age\"] = ")
print(person["age"])

// Test 9: Range function
print("=== Test 9: Range Function ===")
print("range(3) = ")
var numbers = range(3)
for i in numbers {
    print(i)
}

print("=== All Tests Complete ===")
