// Comprehensive AUL Interpreter Test Suite
// This tests all the bugs that were fixed

print("=== AUL Interpreter Bug Fix Validation ===\n")

// Test 1: elif/else chain parsing (Bug #1 fix)
print("Test 1: If/elif/else Chain Parsing")
func testIfElif(x) {
    if x < 0 {
        "negative" ~
    } elif x == 0 {
        "zero" ~
    } elif x < 10 {
        "small positive" ~
    } else {
        "large" ~
    }
}
print("  testIfElif(-5) = " .. testIfElif(-5))
print("  testIfElif(0) = " .. testIfElif(0))
print("  testIfElif(5) = " .. testIfElif(5))
print("  testIfElif(20) = " .. testIfElif(20))
print("")

// Test 2: .toString() method (Bug #4 fix)
print("Test 2: Method Calls (.toString() and .type())")
var num = 42
var str = "hello"
var bool_val = true
print("  num.toString() = " .. num.toString())
print("  str.toString() = " .. str.toString())
print("  bool_val.toString() = " .. bool_val.toString())
print("  num.type() = " .. num.type())
print("")

// Test 3: ForInStmt environment scoping (Bug #5 fix)
print("Test 3: For-In Loop Variable Scoping")
var tbl = {
    a = 1,
    b = 2,
    c = 3
}
print("  Iterating over table:")
for key, val in tbl {
    print("    " .. key.toString() .. " = " .. val.toString())
}
print("")

// Test 4: Numeric for loop with .toString() (Bug #3 and #4 combined)
print("Test 4: Numeric For Loop with toString()")
for i = 0, 5 {
    print("  i = " .. i.toString())
}
print("")

// Test 5: String concatenation with expressions (Bug #6 - better error messages)
print("Test 5: String Concatenation with Type Checking")
var x = 10
var y = 20
var concat_result = "Result: " .. (x + y).toString()
print("  " .. concat_result)
print("")

// Test 6: Bitwise operators with proper type info
print("Test 6: Bitwise Operations")
print("  5 & 3 = " .. (5 & 3).toString())
print("  5 | 3 = " .. (5 | 3).toString())
print("  ~2 = " .. (~2).toString())
print("")

// Test 7: Comparison operators
print("Test 7: Comparison Operations")
print("  5 < 10 = " .. (5 < 10).toString())
print("  10 > 5 = " .. (10 > 5).toString())
print("  5 == 5 = " .. (5 == 5).toString())
print("  5 != 3 = " .. (5 != 3).toString())
print("")

// Test 8: Break and continue in loops
print("Test 8: Break and Continue")
var sum = 0
for i = 0, 10 {
    if i == 3 {
        continue
    }
    if i == 7 {
        break
    }
    sum = sum + i
}
print("  Sum of 0..10 (skip 3, stop at 7) = " .. sum.toString())
print("")

// Test 9: Table operations with none values
print("Test 9: Table Operations and None Values")
var my_table = {
    name = "test",
    value = 42
}
print("  my_table.name = " .. my_table.name.toString())
print("  my_table.value = " .. my_table.value.toString())
print("  my_table.missing = " .. my_table.missing.toString())
print("")

// Test 10: Immutable variable validation (Bug #8 fix)
print("Test 10: Mutable vs Immutable Variables")
var mutable_var = 10
mutable_var = 20
print("  After reassigning mutable_var: " .. mutable_var.toString())

val immutable_var = 30
print("  immutable_var (declared with val) = " .. immutable_var.toString())
print("")

// Test 11: Function with multiple parameters
print("Test 11: Functions with Parameters")
func multiply(a, b, c) {
    a * b * c ~
}
print("  multiply(2, 3, 4) = " .. multiply(2, 3, 4).toString())
print("")

// Test 12: Nested function calls
print("Test 12: Nested Function Calls")
func double_it(n) {
    n * 2 ~
}
func add(a, b) {
    a + b ~
}
print("  double_it(add(5, 3)) = " .. double_it(add(5, 3)).toString())
print("")

// Test 13: While loop
print("Test 13: While Loop")
var count = 0
var result = 0
while count < 5 {
    result = result + count
    count = count + 1
}
print("  Sum 0+1+2+3+4 = " .. result.toString())
print("")

// Test 14: Complex expressions
print("Test 14: Complex Expressions")
var a = 10
var b = 20
var c = (a + b) * 2
print("  (10 + 20) * 2 = " .. c.toString())
print("  (a + b) == 30 = " .. ((a + b) == 30).toString())
print("")

// Test 15: Error handling - Division by zero should show good error
print("Test 15: Error Handling") 
var safe_div = 10 / 2
print("  10 / 2 = " .. safe_div.toString())
print("")

print("=== All Tests Completed Successfully ===")
